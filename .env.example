# Copier vers .env.local (dev) ou variables d'environnement sur l'hébergeur (prod).
# Ne jamais committer .env.local ni la clé service_role.

# Supabase — Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Déploiement (ex. Vercel) :
# - Ajouter les deux variables ci-dessus dans le dashboard du projet (Production + Preview).
# - Build : Vercel exécute `npm run build` (voir package.json).
# - Supabase → Authentication → URL configuration :
#   Site URL = https://ton-domaine.com (ou l’URL Vercel de prod)
#   Redirect URLs : au minimum
#     - http://localhost:3000/**
#     - https://*.vercel.app/**   (previews + déploiements Vercel)
#     - https://ton-domaine.com/** (prod finale)
# Guide pas à pas : docs/DEPLOY_VERCEL.md
