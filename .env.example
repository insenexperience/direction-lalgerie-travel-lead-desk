# Copier vers .env.local (dev) ou variables d'environnement sur l'hébergeur (prod).
# Ne jamais committer .env.local ni la clé service_role.

# Supabase — Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Déploiement (ex. Vercel) :
# - Ajouter les deux variables ci-dessus dans le dashboard du projet (Production + Preview).
# - Build : Vercel exécute `npm run build` (voir package.json).
# - Supabase → Authentication → URL configuration :
#   Site URL = https://ton-domaine.com (ou l’URL Vercel de prod)
#   Redirect URLs : au minimum
#     - http://localhost:3000/**
#     - https://*.vercel.app/**   (previews + déploiements Vercel)
#     - https://ton-domaine.com/** (prod finale)
# Guide pas à pas : docs/DEPLOY_VERCEL.md

# OpenAI (serveur uniquement — ne jamais préfixer NEXT_PUBLIC_)
OPENAI_API_KEY=
# Optionnel : défaut gpt-4o
OPENAI_MODEL=

# WhatsApp Cloud API (webhook + envoi)
WHATSAPP_PHONE_NUMBER_ID=
# Jeton d’accès Graph (préféré) ; sinon WHATSAPP_ACCESS_TOKEN est accepté.
WHATSAPP_API_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
# Optionnel : secret app pour vérifier X-Hub-Signature-256 sur POST
WHATSAPP_APP_SECRET=
# Optionnel : nom du template Meta pour le 1er message de qualification
WHATSAPP_QUALIFICATION_TEMPLATE=

# Supabase service role : routes API / webhooks sans session (jamais NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=

# POST public `/api/intake` (formulaire Squarespace) — CORS en production
ALLOWED_ORIGIN=https://www.direction-lalgerie.com
# Optionnel : si défini, la route exige Authorization: Bearer <secret> ou header X-Intake-Secret
INTAKE_SHARED_SECRET=
